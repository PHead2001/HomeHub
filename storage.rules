rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function householdMember(householdId) {
      return signedIn() &&
        request.auth.token.email in
          firestore.get(/databases/(default)/documents/households/$(householdId)).data.memberEmails;
    }

    function validMaintenanceFile() {
      return request.resource != null &&
        request.resource.size < 15 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*|application/pdf|text/plain|application/msword|application/vnd.openxmlformats-officedocument.*');
    }

    match /households/{householdId}/maintenance/{targetType}/{targetId}/{fileName} {
      allow read: if householdMember(householdId);
      allow create, update: if householdMember(householdId) &&
        targetType in ['home_asset', 'vehicle', 'maintenance_log'] &&
        validMaintenanceFile();
      allow delete: if householdMember(householdId);
    }

    match /households/{householdId}/barcode-library/{allPaths=**} {
      allow read, write: if householdMember(householdId);
    }

    match /households/{householdId}/pets/{allPaths=**} {
      allow read, write: if householdMember(householdId);
    }

    match /users/{userEmail}/avatars/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.token.email == userEmail;
    }
  }
}
